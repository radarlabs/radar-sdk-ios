#!/bin/sh
# Save real Radar API keys to .radar-keys before commit
# The clean filter handles sanitization; this just persists keys for the smudge filter
KEYS_FILE="$(git rev-parse --git-dir)/radar-keys"
ZERO='0000000000000000000000000000000000000000'

FILES=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$FILES" ]; then
    exit 0
fi

touch "$KEYS_FILE"
for file in $FILES; do
    [ -f "$file" ] || continue
    for key in $(grep -oE 'prj_(test|live)_(pk|sk)_[0-9a-fA-F]{40}' "$file" 2>/dev/null); do
        case "$key" in *"$ZERO") continue ;; esac
        prefix=$(echo "$key" | sed -E 's/[0-9a-fA-F]{40}$//')
        if ! grep -q "^${prefix}" "$KEYS_FILE" 2>/dev/null; then
            echo "$key" >> "$KEYS_FILE"
        fi
    done
done
